# Optional. If set, the /api/chat route uses this key for all visitors (you pay per query).
# If unset, the chat still works: visitors can paste their own key (kept only in their browser
# tab), and with no key at all it falls back to surfacing the most relevant lessons.
ANTHROPIC_API_KEY=

# Optional. Model for chat answers. Defaults to claude-haiku-4-5 (cheapest/fastest for doc Q&A).
# ANTHROPIC_MODEL=claude-haiku-4-5
